# Python
**/__pycache__/
*.pyc
.env

# Shared dataset cache — built by build_dataset.py at training time.
# These files are large (1-5 GB) and are regenerated automatically.
# Do not commit them — training scripts will rebuild if missing.
dataset/raw/
dataset/windows_756.npz
dataset/windows_252.npz
# Keep dataset/meta.json out too — it references local paths
dataset/meta.json

# Node
frontend/node_modules/
nextjs/node_modules/
nextjs/.next/

# MLflow run data — large, no need to commit
mlruns/

# Training data dump files (large intermediate arrays)
# The actual model checkpoints (.pth, .pkl) ARE committed
# so GitHub Actions can retrain and push them back.
transformer_final/X_te.pkl
transformer_final/X_tr.pkl
transformer_final/Ret_te.pkl
transformer_final/Ret_tr.pkl
transformer_final/Px_te.pkl
transformer_final/Px_tr.pkl
transformer_final/LC_te.pkl
transformer_final/LC_tr.pkl

# Misc
*.zip
*.tar
*.gz
.DS_Store
